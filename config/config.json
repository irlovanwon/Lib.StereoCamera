{
    "api1": {
        "camera_sdk": {
            "host": "127.0.0.1",
            "port": 8443,
            "cert_path": "",
            "timeout_ms": 5000
        },
        "data": {
            "transport": "ipc",
            "channels": {
                "base": "ipc:///tmp/zed_vision",
                "visual_2d": "ipc:///tmp/zed_vision_visual_2d",
                "sensor_data": "ipc:///tmp/zed_vision_sensor_data",
                "visual_3d": "ipc:///tmp/zed_vision_visual_3d"
            }
        }
    },
    "api2": {
        "server": {
            "host": "0.0.0.0",
            "port": 8444,
            "cert_path": "",
            "key_path": "",
            "thread_strategy": "hybrid",
            "worker_threads": 4
        },
        "data": {
            "transport": "ipc",
            "zmq_hwm": 30,
            "pub_endpoints": {
                "visual_geometric_2d": "ipc:///tmp/sc_pub_2d",
                "visual_geometric_3d": "ipc:///tmp/sc_pub_3d",
                "sensor_tracking": "ipc:///tmp/sc_pub_sensor"
            }
        }
    },
    "api3": {
        "admin_server": {
            "host": "127.0.0.1",
            "port": 9443,
            "cert_path": "config/server.crt",
            "key_path": "config/server.key",
            "thread_strategy": "hybrid",
            "worker_threads": 4
        },
        "data": {
            "wss_server": {
                "host": "127.0.0.1",
                "port": 9444,
                "cert_path": "",
                "key_path": "",
                "thread_strategy": "one_loop_per_thread",
                "worker_threads": 2
            },
            "zmq_hwm": 30,
            "sub_endpoints": {
                "visual_geometric_2d": "ipc:///tmp/sc_pub_2d",
                "visual_geometric_3d": "ipc:///tmp/sc_pub_3d",
                "sensor_tracking": "ipc:///tmp/sc_pub_sensor"
            }
        }
    },
    "spsc": {
        "queue_size": 4,
        "drop_policy": "newest",
        "gst_encode_timeout_ms": 1000,
        "publish_cv_timeout_ms": 10,
        "encode_cv_timeout_ms": 10,
        "send_cv_timeout_ms": 10
    },
    "data_buffer_depth": 1,
    "log_level": "info"
}